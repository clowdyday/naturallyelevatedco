# ─────────────────────────────────────────────────────────────
# Naturally Elevated Co. — Cloudflare Worker Environment Variables
# Copy this file to .env and fill in your values.
# Set these in the Cloudflare dashboard:
#   Workers & Pages → naturallyelevated-co → Settings → Variables
# ─────────────────────────────────────────────────────────────

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...

# Stripe webhook secret — https://dashboard.stripe.com/webhooks
# Point the webhook to: https://naturallyelevated.co/api/webhook
# Events to enable: checkout.session.completed
STRIPE_WEBHOOK_SECRET=whsec_...

# Printify — https://printify.com/app/account/connections
PRINTIFY_API_KEY=...

# Your Printify shop ID — https://printify.com/app/account/shops
PRINTIFY_SHOP_ID=...

# Your site's public origin (no trailing slash)
PUBLIC_SITE_ORIGIN=https://naturallyelevated.co
