# Naturally Elevated Co. — Environment Variables
# Copy this file to .env for local development (never commit .env)
#
# Add these 4 variables in Netlify dashboard:
#   Site settings → Environment variables → Add variable

# ── Stripe ──────────────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Get from: https://dashboard.stripe.com/webhooks (after creating endpoint)
# Endpoint URL: https://naturallyelevatedco.com/api/webhook
# Event to listen for: checkout.session.completed
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Printify ─────────────────────────────────────────────────────────────────
# Get from: https://printify.com/app/account/connections (API token)
PRINTIFY_API_KEY=

# Get from: https://printify.com/app/store (the numeric ID in the URL)
PRINTIFY_SHOP_ID=

# ── Local dev only ───────────────────────────────────────────────────────────
# Netlify auto-injects this in production. Required locally for checkout redirects.
URL=http://localhost:8888
